#!/usr/bin/make -f

export CARGO_HOME = $(CURDIR)/debian/cargo_home

%:
	dh $@

override_dh_auto_build:
	cargo build --release --features full-syntax

override_dh_auto_install:
	install -Dm755 target/release/notepadx debian/notepadx/usr/bin/notepadx
	install -Dm644 assets/logo-256.png debian/notepadx/usr/share/icons/hicolor/256x256/apps/notepadx.png
	install -Dm644 debian/notepadx.desktop debian/notepadx/usr/share/applications/notepadx.desktop
	install -Dm644 debian/notepadx.1 debian/notepadx/usr/share/man/man1/notepadx.1

override_dh_auto_test:
	# Tests require a display server; skip in packaging builds
	true

override_dh_auto_clean:
	cargo clean || true
	rm -rf $(CARGO_HOME)

override_dh_shlibdeps:
	dh_shlibdeps -l/usr/lib/x86_64-linux-gnu
