[Desktop Entry]
Type=Application
Name=NotepadX
GenericName=Text Editor
Comment=Fast native text editor with GPU rendering
Exec=notepadx %F
Icon=notepadx
Terminal=false
Categories=Utility;TextEditor;Development;GTK;
MimeType=text/plain;text/x-csrc;text/x-c++src;text/x-java;text/x-python;text/x-shellscript;application/json;application/xml;text/html;text/css;text/javascript;text/x-rust;text/x-go;text/x-lua;text/x-ruby;text/x-php;text/markdown;text/x-toml;text/x-yaml;
StartupNotify=true
Keywords=text;editor;notepad;code;
